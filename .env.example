# Frontend (Vite) — used at build time for production bundles.
# On Vercel: set these in Project → Settings → Environment Variables (Production + Preview).

# GCP API URL (nginx / load balancer in front of the engine VM)
VITE_API_BASE=https://api.yourdomain.com

# Optional: Bearer token for POST /api/control/* (embedded in the client bundle — protect the dashboard)
# VITE_API_TOKEN=
