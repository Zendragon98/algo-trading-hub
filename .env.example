# Optional frontend deployment variables only.
# Local development does not need a root .env file because Vite proxies /api and
# /ws to the backend. Backend/trading configuration belongs in backend/.env.
#
# On Vercel or another frontend host, set these in the host/build environment
# instead of relying on a checked-in file.

# GCP API URL (nginx / load balancer in front of the engine VM)
VITE_API_BASE=https://api.yourdomain.com

# Optional: Bearer token for POST /api/control/*.
# This is embedded in the client bundle; protect the dashboard with network or
# host-level access controls.
# VITE_API_TOKEN=
