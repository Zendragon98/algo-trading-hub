            ORD["order_connection.py<br/>orders · listenKey keepalive"]
            ACC["account_connection.py<br/>balances · positions"]
        end
        BG --> REST & MKT & ORD & ACC
    end

    subgraph BinanceAPI["Binance USDT-M Futures"]
        R1["REST /fapi/v2/*"]
