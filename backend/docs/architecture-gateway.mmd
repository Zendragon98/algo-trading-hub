%% Gateway seam — Binance adapter internals
flowchart LR
    subgraph Engine["Engine (venue-agnostic)"]
        E1["subscribe_market_data"]
        E2["subscribe_user_data"]
        E3["place_order / cancel_order"]
        E4["fetch_balances_and_positions"]
        E5["book_snapshot"]
    end

    subgraph Interface["gateways/gateway_interface.py"]
        IF["GatewayInterface ABC<br/>SymbolFilters · callbacks"]
    end

    subgraph BinanceGW["gateways/binance/binance_gateway.py"]
