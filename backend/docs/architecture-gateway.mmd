        CB1["on_tick · on_depth · on_trade"]
        CB2["on_fill · on_order_update"]
        CB3["on_account_update · on_ws_connected"]
        CB4["on_quote_volume_24h · on_reconnect"]
    end

    MKT --> CB1
    ORD --> CB2
    ORD --> CB3
    MKT --> CB4

