%% Gateway seam - venue-agnostic engine and exchange adapters
flowchart LR
    subgraph Engine["Engine calls"]
        MKT_SUB["subscribe_market_data"]
        USER_SUB["subscribe_user_data"]
        ORDERS["place_order<br/>cancel_order"]
        ACCOUNT["fetch balances<br/>and positions"]
        BOOK["book_snapshot"]
    end

    subgraph Interface["gateways/gateway_interface.py"]
        ABC["GatewayInterface<br/>adapter contract + callbacks"]
    end

    subgraph Binance["Binance adapter"]
        BG["BinanceGateway"]
        REST["rest_client.py<br/>signed HTTP + throttling"]
        MARKET["market_connection.py<br/>public streams + reconnect"]
        ORDER["order_connection.py<br/>orders + listenKey"]
        ACCT["account_connection.py<br/>balances + positions"]
        BG --> REST
        BG --> MARKET
        BG --> ORDER
        BG --> ACCT
    end

    subgraph IBKR["IBKR adapter scaffold"]
        IB["gateways/ibkr/<br/>connector scaffold"]
    end

    subgraph Venue["External venues"]
        BREST["Binance REST /fapi"]
        BWS["Binance public WebSocket"]
        BUSR["Binance user stream"]
        TWS["IBKR TWS / Gateway"]
    end

    MKT_SUB --> ABC
    USER_SUB --> ABC
    ORDERS --> ABC
    ACCOUNT --> ABC
    BOOK --> ABC

    ABC --> BG
    ABC -.-> IB
    REST --> BREST
    ORDER --> BREST
    MARKET --> BWS
    ORDER --> BUSR
    IB -.-> TWS

    subgraph Callbacks["Callbacks into Engine"]
        MARKET_CB["on_tick<br/>on_depth<br/>on_trade"]
        ORDER_CB["on_fill<br/>on_order_update"]
        ACCOUNT_CB["on_account_update<br/>on_ws_connected (Binance only)"]
        META_CB["on_quote_volume_24h<br/>on_reconnect"]
    end

    MARKET --> MARKET_CB
    ORDER --> ORDER_CB
    ORDER --> ACCOUNT_CB
    MARKET --> META_CB

    classDef engine fill:#eff6ff,stroke:#3b82f6,color:#172554
    classDef seam fill:#fef3c7,stroke:#f59e0b,color:#78350f
    classDef adapter fill:#f0fdf4,stroke:#22c55e,color:#14532d
    classDef venue fill:#fef2f2,stroke:#ef4444,color:#7f1d1d

    class MKT_SUB,USER_SUB,ORDERS,ACCOUNT,BOOK engine
    class ABC seam
    class BG,REST,MARKET,ORDER,ACCT,IB,MARKET_CB,ORDER_CB,ACCOUNT_CB,META_CB adapter
    class BREST,BWS,BUSR,TWS venue
