%% Position and portfolio truth - venue, engine, API, dashboard
flowchart TB
    VENUE["Venue account<br/>source of truth"]

    subgraph Gateway["Gateway inputs"]
        USERWS["User-data WebSocket<br/>ACCOUNT_UPDATE + ORDER_TRADE_UPDATE"]
        REST["REST snapshots<br/>account, positions, open orders"]
        RECON["Periodic reconcile<br/>used when streams are stale or drifted"]
    end

    VENUE --> USERWS
    VENUE --> REST --> RECON

    subgraph Engine["Engine state"]
        POS["PositionTracker<br/>qty, entry, realised PnL"]
        PORT["Portfolio<br/>wallets + equity curve"]
        OMS["OrderManager<br/>working child orders"]
    end

    USERWS -->|"merge exchange state"| POS
    USERWS -->|"merge wallet state"| PORT
    USERWS -->|"order/fill updates"| OMS
    REST -->|"startup seed + explicit resync"| POS
    REST -->|"startup seed + balance resync"| PORT
    RECON --> POS
    RECON --> PORT
    RECON --> OMS

    subgraph Drift["Drift handling"]
        HEAL["Optional heal<br/>overwrite local from venue"]
        BREAKER["MAJOR breaker<br/>reconcile mismatch"]
        ORPHAN["Open-order reconcile<br/>cancel or flag orphans"]
    end

    RECON --> HEAL
    RECON --> BREAKER
    RECON --> ORPHAN

    subgraph API["API surface"]
        SNAPSHOT["GET /api/state<br/>engine snapshot"]
        STREAM["WebSocket /ws<br/>position, equity, order events"]
    end

    POS --> SNAPSHOT
    POS --> STREAM
    PORT --> SNAPSHOT
    PORT --> STREAM
    OMS --> SNAPSHOT
    OMS --> STREAM

    subgraph Dashboard["React dashboard"]
        HOOK["useAlgoStream"]
        POLL["5 second state poll<br/>plus focus/reconnect hydrate"]
        HOOK --> POLL
    end

    SNAPSHOT --> HOOK
    STREAM --> HOOK

    classDef venue fill:#fef2f2,stroke:#ef4444,color:#7f1d1d
    classDef gateway fill:#eff6ff,stroke:#3b82f6,color:#172554
    classDef engine fill:#f0fdf4,stroke:#22c55e,color:#14532d
    classDef risk fill:#fff7ed,stroke:#f97316,color:#7c2d12
    classDef api fill:#f5f3ff,stroke:#8b5cf6,color:#2e1065

    class VENUE venue
    class USERWS,REST,RECON gateway
    class POS,PORT,OMS engine
    class HEAL,BREAKER,ORPHAN risk
    class SNAPSHOT,STREAM,HOOK,POLL api
