%% Engine bootstrap and shutdown — main.py + Engine.start/stop
sequenceDiagram
    autonumber
    participant M as main.py
    participant B as EventBus
    participant R as bootstrap_run
    participant G as Gateway
    participant E as Engine
    participant U as uvicorn

    M->>B: EventBus()
    M->>R: bootstrap_run(settings)<br/>run dir · WAL · recorder
    M->>G: create_gateway(VENUE)
    M->>E: Engine(settings, strategies, recovery_wal)
    Note over M,E: Wire equity/weight providers into strategies

    alt ENGINE_AUTOSTART or --engine
        M->>E: start()
    else default / --no-engine
        Note over E: status=STOPPED until POST /control/start
    end

    rect rgb(30, 41, 59)
        Note over E,G: Engine.start() sequence
        E->>G: connect() + sync_server_time
        opt RECOVER_ON_START
            E->>E: replay WAL → OMS + positions
        end
        E->>G: REST book snapshots (all symbols)
        E->>G: subscribe_market_data(WS)
        E->>G: prime mids (bookTicker wait → REST depth fallback)
        E->>G: fetch_balances_and_positions()
        E->>E: seed portfolio + PositionTracker
        E->>E: order_reconcile sync_startup
        E->>G: subscribe_user_data(WS)
        E->>E: volume_weights refresh
        E->>E: clock.start() + reconciler loops
    end

    M->>U: create_app(engine, bus) + serve()

    Note over U: SIGINT/SIGTERM → shutdown

    U-->>M: stop_event
    M->>E: stop()
    rect rgb(55, 30, 30)
        opt FLATTEN_ON_STOP
            E->>E: flatten_and_wait_for_flat
        end
        E->>E: cancel reconcilers · router shutdown
        E->>G: cancel_all_open_orders
        E->>G: disconnect()
    end
    M->>R: shutdown_bootstrap
