# Copy to backend/.env and fill in your Binance USDT-M Futures Testnet credentials.
# Generate keys at https://testnet.binancefuture.com/ -> "API Key" tab.

# --- Binance Futures Testnet ---
BINANCE_API_KEY=your_testnet_key_here
BINANCE_API_SECRET=your_testnet_secret_here
BINANCE_TESTNET=true

# REST + WS base URLs. Override only if you point at a different mock/sandbox.
BINANCE_REST_BASE=https://testnet.binancefuture.com
BINANCE_WS_BASE=wss://stream.binancefuture.com

# --- Engine ---
# Comma-separated Futures symbols. Each pair must have both legs (USDT + USDC)
# for the pairs-trading strategy to consider it.
SYMBOLS=BTCUSDT,BTCUSDC,ETHUSDT,ETHUSDC

# Quote currency used to denominate equity / PnL on the dashboard.
BASE_CURRENCY=USDT

# --- Risk limits ---
# Max % of equity risked per single parent order. Surfaced in the UI slider.
MAX_RISK_PCT=0.35

# Hard exposure ceiling in quote currency.
MAX_GROSS_NOTIONAL=50000

# Max permitted drawdown from session-start equity before the engine flat-stops.
MAX_DRAWDOWN_PCT=0.10

# Per-position stop loss / take profit (fraction of entry).
DEFAULT_STOP_LOSS_PCT=0.005
DEFAULT_TAKE_PROFIT_PCT=0.010

# --- Execution ---
# VWAP parent-order duration (seconds) and number of child slices.
VWAP_DURATION_SEC=60
VWAP_NUM_SLICES=6

# Order book depth used for imbalance calculation (top-N levels per side).
IMBALANCE_TOP_N=10

# Trade-tape rolling window for the bid-hit / ask-hit ratio.
TRADE_TAPE_WINDOW_SEC=300

# --- Synthetic market impact ---
# Testnet has unrealistically deep books, so fills look too clean. When
# enabled, the engine adjusts recorded fill prices by an estimated impact
# cost so PnL reflects what mainnet would look like. Disable to use raw
# venue fills only.
IMPACT_MODEL_ENABLED=true
IMPACT_K=0.5

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000

# Comma-separated origins allowed by CORS. Vite dev defaults to 5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Persistence ---
# Each engine start creates `<PERSIST_DIR>/<run_id>/` with a rotating
# `app.log` and one JSONL file per event stream (fills, executions,
# parents, positions, equity, orders, signals, status). Set
# PERSIST_RECORD_TICKS=true to also dump every TICK (very high volume).
PERSIST_ENABLED=true
PERSIST_DIR=data/runs
PERSIST_RECORD_TICKS=false
LOG_FILE_ENABLED=true
LOG_FILE_MAX_BYTES=10000000
LOG_FILE_BACKUP_COUNT=5
