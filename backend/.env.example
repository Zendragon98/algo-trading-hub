# backend/.env - optional local overrides
#
# Copy this file to backend/.env before local runs:
#   copy .env.example .env
#   cp .env.example .env
#
# Keep real secrets only in backend/.env. Do not commit .env files.

# Binance Demo/Testnet keys are needed only when the engine connects to
# account, user-data, position, or order endpoints. API-only startup and the
# no-key offline smoke backtest do not need keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Safe course-review profile. These match the code defaults and are listed here
# to make the intended local posture explicit.
# TRADING_MODE=paper
# BINANCE_TESTNET=true
# ENGINE_AUTOSTART=false

# Common local overrides.
# VENUE=binance
# API_HOST=127.0.0.1
# API_PORT=8000
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# LOG_LEVEL=info

# Strategy and universe examples. Use one STRATEGY value at a time.
# STRATEGY=pairs
# SYMBOLS=BTCUSDT,BTCUSDC
# STRATEGY=sma
# SMA_SYMBOLS=BTCUSDT,ETHUSDT
# STRATEGY=blended_signals
# BLEND_SYMBOLS=BTCUSDT,ETHUSDT
# STRATEGY=market_making_v2
# MM2_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Risk examples. Defaults live in common/config/sections/.
# DEFAULT_STOP_LOSS_PCT=0.02
# DEFAULT_TAKE_PROFIT_PCT=0.06
# MAX_RISK_PCT=0.35
# MAX_SYMBOL_NOTIONAL_PCT=1.0
# MAX_OPEN_PARENTS=16
# RECONCILE_INTERVAL_SEC=60

# Analytics worker and local backtest jobs.
# ANALYTICS_WORKER_ENABLED=true
# ANALYTICS_WORKER_MODE=embedded
# ANALYTICS_JOBS_DIR=data/jobs

# Binance mainnet/live example. Use only with real-money keys and review the
# safety controls in docs/SECURITY.md and docs/OPERATIONS.md first.
# TRADING_MODE=live
# BINANCE_TESTNET=false
# BINANCE_REST_BASE=https://fapi.binance.com
# BINANCE_WS_BASE=wss://fstream.binance.com
