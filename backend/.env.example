# =============================================================================
# backend/.env — optional overrides only
# =============================================================================
# Every setting has a default in code: see `common/config.py` (class Settings).
# Add variables here only when you need to override defaults (secrets, URLs,
# risk tuning, etc.). Do not duplicate the full Settings surface into this file.
#
# Copy to `.env`:  copy .env.example .env   |   cp .env.example .env
# Testnet keys:    https://testnet.binancefuture.com → API Key tab
# =============================================================================

# --- Binance (required for live/testnet trading) ---
BINANCE_API_KEY=your_testnet_key_here
BINANCE_API_SECRET=your_testnet_secret_here

# --- Uncomment only what you change from `Settings` defaults ---
# VENUE=binance
# TRADING_MODE=paper
# BINANCE_TESTNET=true
# BINANCE_REST_BASE=https://testnet.binancefuture.com
# BINANCE_WS_BASE=wss://stream.binancefuture.com
# BINANCE_REST_MIN_INTERVAL_MS=100   # raise if you still hit Binance -1003 weight limits

# SYMBOLS=AUTO
# STRATEGY=pairs
# BASE_CURRENCY=USDT
# ENGINE_AUTOSTART=false

# --- Risk / behaviour: defaults live in common/config.py (Settings) ---
# Paper OMS stress (SMA + blend): 2% SL / 6% TP, 12% risk per strategy, 15m bars.
# DEFAULT_STOP_LOSS_PCT=0.02
# DEFAULT_TAKE_PROFIT_PCT=0.06
# MAX_RISK_PCT=1.0
# MAX_SYMBOL_NOTIONAL_PCT=1.0
# SMA_BAR_INTERVAL_SEC=900
# SMA_SYMBOLS=BTCUSDT,ETHUSDT
# SMA_RISK_PER_TRADE_PCT=0.12
# BLEND_BAR_INTERVAL_SEC=900
# BLEND_SYMBOLS=BTCUSDT,ETHUSDT
# BLEND_RISK_PER_TRADE_PCT=0.12
# Pairs trading (USDT/USDC basis) — recommended universe: BTC + ETH + SOL only
# SYMBOLS=BTCUSDT,BTCUSDC,ETHUSDT,ETHUSDC,SOLUSDT,SOLUSDC
# STRATEGY=pairs
# PAIR_REFERENCE_MODE=btc_anchor
# PAIR_BAR_SEC=60
# PAIR_ENTRY_Z=2.5
# PAIR_EXIT_Z=0.4
# PAIR_STOP_Z=3.5
# PAIR_Z_WINDOW_SEC=600
# PAIR_MIN_Z_SAMPLES=30
# PAIR_MIN_Z_SAMPLES=120
# ^ use 120 when PAIR_BAR_SEC=0
# PAIR_COOLDOWN_SEC=120
# PAIR_STOP_COOLDOWN_SEC=300
# PAIR_MAX_HOLD_SEC=1800
# PAIR_MAX_LEG_NOTIONAL=500
# PAIR_MAX_LEG_LOSS_USD=25
# PAIR_SIZE_SCALE_CAP=2.0
# PAIR_MIN_MID_PRICE=0.01
# PAIR_VOLUME_FROM_WEBSOCKET=true
# RISK_PER_TRADE_PCT=0.005
# MAX_RISK_PCT=0.35
# RECONCILE_INTERVAL_SEC=60
# MAX_OPEN_PARENTS=16
# RECONCILE_CANCEL_ORPHANS=true
# MM_MAX_ENTRIES_PER_TICK=4
# Per-symbol MM half-spreads (bps): JSON or CSV — not one spread for all coins
# MM_SYMBOL_HALF_SPREAD_BPS=BTCUSDT:2,ETHUSDT:3,SOLUSDT:4,DOGEUSDT:12,XRPUSDT:8
# MM_QUOTE_USE_VENUE_SPREAD_FLOOR=true
# MM_QUOTE_VENUE_SPREAD_MULT=1.0
# L2 ingest + calibrate starting spreads (run before MM live):
# python -m analytics.mm_spread_pipeline --from-mm-symbols --minutes 15
# SYMBOL_CALIBRATION_PATH=data/symbol_calibration.json
# MM_SPREAD_CALIBRATION_PATH=data/mm_spread_calibration.json
# --- Market making v2 (recommended; v1 deprecated) ---
# STRATEGY=market_making_v2
# MM2_SYMBOLS=SOLUSDT,AVAXUSDT,ARBUSDT
# MM2_MIN_SPREAD_BPS=0
# MM2_MIN_SKEW_BPS=1.5
# MM2_TAPE_CONFIRM=0.10
# MM2_SKEW_WINDOW_SEC=180
# MM2_MIN_SAMPLES=60
# MM2_MAX_HOLD_SEC=60
# MM2_MIN_EXIT_PROFIT_BPS=4.0
# MM2_AGGRESSIVE_EXIT_LOSS_BPS=8.0
# MM2_MARKET_EXIT_LOSS_BPS=12.0
# MM2_MAX_CONCURRENT_POSITIONS=2
# MM2_MAX_INVENTORY_NOTIONAL=300
# MM2_VOL_REGIME_SPIKE_MULT=1.8
# MM2_VOL_REGIME_PAUSE_SEC=90
# MM_URGENT_EXIT_MARKET=true
# MM2_QUOTE_DURING_WARMUP=false
# IMBALANCE_THRESHOLD=0.20
# HIT_RATIO_THRESHOLD=0.60
# FLATTEN_MARKET_MAX_NOTIONAL_USD=250
# FLATTEN_VWAP_MIN_NOTIONAL_USD=1500
# FLATTEN_TIMEOUT_SEC=30

# --- Logging (console, app.log, LIVE LOG, logs.jsonl) ---
# LOG_LEVEL=debug   # debug | info | warning | error — use debug to verify feeds, WS, reconciliation

# --- Analytics worker (backtest/download off the trading process) ---
# ANALYTICS_WORKER_ENABLED=true
# ANALYTICS_WORKER_MODE=embedded   # embedded | external | disabled
# ANALYTICS_JOBS_DIR=data/jobs

# --- API ---
# API_HOST=127.0.0.1
# API_PORT=8000
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Interactive Brokers (only when VENUE=ibkr) ---
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=7

# --- Example: Binance mainnet + live ---
# TRADING_MODE=live
# BINANCE_TESTNET=false
# BINANCE_REST_BASE=https://fapi.binance.com
# BINANCE_WS_BASE=wss://fstream.binance.com
