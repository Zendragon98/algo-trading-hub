# deploy/gcp/.env — used by docker compose on the VM.
# Copy:  cp env.gcp.example .env
# Never commit .env (secrets).

# Container image (Artifact Registry or local tag)
IMAGE=us-central1-docker.pkg.dev/YOUR_PROJECT/algo-trading/backend:latest

# Host path for run archives, jobs, calibration caches
DATA_DIR=/var/lib/algo-trading/data

# --- Backend (maps to backend/common/config.py) ---
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN=generate-a-long-random-token

# Dashboard origin(s) — required when the UI is on a different host than the API
# Vercel: https://your-project.vercel.app (+ custom domain, preview URLs if used)
CORS_ORIGINS=https://your-project.vercel.app

TRADING_MODE=paper
BINANCE_TESTNET=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Safer prod default: boot API only; start trading from the console
ENGINE_AUTOSTART=false

# Block rapid strategy hot-swaps (soak scripts / accidental UI spam)
STRATEGY_SWAP_MIN_INTERVAL_SEC=5

# --- STRATEGY=all wide paper profile ---
STRATEGY=all
MULTI_STRATEGY_PARTITION=true

# Pairs: multi-base USDT+USDC legs (partition also sets SYMBOLS when AUTO)
SYMBOLS=AUTO
MULTI_STRATEGY_PAIR_BASES=BTC,ETH,SOL,BNB,XRP
PAIR_ENTRY_Z=2.0
PAIR_MIN_Z_SAMPLES=20
PAIR_BAR_SEC=60
PAIR_MAX_NEW_ENTRIES_PER_TICK=3

# Partitioned AUTO universes (non-overlapping single-leg tiers)
MM2_SYMBOLS=AUTO
MM_AUTO_MAX_SYMBOLS=12
SMA_SYMBOLS=AUTO
SMA_MAX_SYMBOLS=10
SMA_BAR_INTERVAL_SEC=300
SMA_MAX_ENTRIES_PER_TICK=3
BLEND_SYMBOLS=AUTO
BLEND_MAX_SYMBOLS=10
BLEND_BAR_INTERVAL_SEC=300
BLEND_ENTRY_THRESHOLD=0.40
BLEND_MIN_CONFIRMING_VOTES=2
BLEND_MAX_ENTRIES_PER_TICK=3
FLOW_SYMBOLS=AUTO
FLOW_MAX_SYMBOLS=10
FLOW_MAX_ENTRIES_PER_TICK=3
FLOW_COOLDOWN_SEC=45
FLOW_CONFIRM_TICKS=5
FLOW_REQUIRE_RISING_TAPE=true
FLOW_MAX_SPREAD_ENTRY_FRAC=0.4
FLOW_MIN_EDGE_BPS=6
FLOW_STOP_LOSS_BPS=14
FLOW_TRAIL_ARM_BPS=8
FLOW_TRAIL_STOP_BPS=6
FLOW_MAX_HOLD_SEC=120
FLOW_MAX_HOLD_LOSS_ONLY=true
FLOW_EXIT_MARKET=true
FLOW_EXIT_CROSS_TOUCH=true
FLOW_EXIT_URGENT_SCORE=1.0

# Concurrency headroom for wider universe
MAX_OPEN_PARENTS=24
MM2_MAX_CONCURRENT_POSITIONS=6
MM_QUOTE_MAX_REFRESH_PER_TICK=16

# MM2 testnet gates (re-calibrate after expand — do not rely on stale cal)
MM2_SPREAD_GATE_MODE=standard
MM2_QUOTE_DURING_WARMUP=true
MM2_TWO_SIDED_ALWAYS=true
MM_QUOTE_AT_TOUCH=true

# Per-symbol MM spreads (refresh via analytics after universe expand)
# SYMBOL_CALIBRATION_PATH=data/symbol_calibration.json

# After deploy / universe expand, on the VM (15–30 min L2 sample):
#   docker compose exec backend python -m analytics.mm_spread_pipeline \
#     --from-mm-symbols --minutes 30 --interval-sec 1
# After soak, per-strategy PnL:
#   docker compose exec backend python -m analytics.strategy_pnl_report --runs-dir data/runs

# Optional alerts
# ALERT_WEBHOOK_URL=
