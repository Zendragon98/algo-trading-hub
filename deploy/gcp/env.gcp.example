# deploy/gcp/.env — used by docker compose on the VM.
# Copy:  cp env.gcp.example .env
# Never commit .env (secrets).

# Container image (Artifact Registry or local tag)
IMAGE=us-central1-docker.pkg.dev/YOUR_PROJECT/algo-trading/backend:latest

# Host path for run archives, jobs, calibration caches
DATA_DIR=/var/lib/algo-trading/data

# --- Backend (maps to backend/common/config.py) ---
API_HOST=0.0.0.0
API_PORT=8000
API_TOKEN=generate-a-long-random-token

# Dashboard origin(s) — required when the UI is on a different host than the API
# Vercel: https://your-project.vercel.app (+ custom domain, preview URLs if used)
CORS_ORIGINS=https://your-project.vercel.app

TRADING_MODE=paper
BINANCE_TESTNET=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Safer prod default: boot API only; start trading from the console
ENGINE_AUTOSTART=false

# Block rapid strategy hot-swaps (soak scripts / accidental UI spam)
STRATEGY_SWAP_MIN_INTERVAL_SEC=5

# Per-symbol MM spreads (seeded from image bundle on first boot; refresh via analytics)
# SYMBOL_CALIBRATION_PATH=data/symbol_calibration.json

# Market making (STRATEGY=market_making_v2 or mm2)
# STRATEGY=market_making_v2
# MM2_QUOTE_DURING_WARMUP=true
# MM2_TWO_SIDED_ALWAYS=true
# MM_QUOTE_AT_TOUCH=true

# Flow momentum (when STRATEGY includes flow_momentum or STRATEGY=all)
# FLOW_MAX_HOLD_SEC=60
# FLOW_EXIT_TAPE_FRAC=0.35
# FLOW_EXIT_TAPE_THRESHOLD=0.05
# FLOW_EXIT_CONFIRM_TICKS=2

# Optional alerts
# ALERT_WEBHOOK_URL=
